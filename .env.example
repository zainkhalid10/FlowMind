# FlowMind Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# Google OAuth Configuration
# ==============================================================================
# To set up Google OAuth:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select existing)
# 3. Enable the "Google+ API"
# 4. Create OAuth 2.0 credentials (choose "Web application")
# 5. Add authorized redirect URIs:
#    - http://localhost:8000/auth/google/callback (for development)
#    - https://yourdomain.com/auth/google/callback (for production)
# 6. Copy the Client ID and Client Secret below

GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ==============================================================================
# JWT Configuration
# ==============================================================================
# Secret key for JWT token signing (generate a new one using secrets.token_urlsafe(32))
# Keep this private and do NOT commit to version control!
SECRET_KEY=your-secret-key-here

# ==============================================================================
# Database Configuration
# ==============================================================================
# SQLite database URL (default is fine for development)
DATABASE_URL=sqlite:///./flowmind.db

# ==============================================================================
# Server Configuration
# ==============================================================================
# Server host and port (usually don't need to change)
HOST=0.0.0.0
PORT=8000

# ==============================================================================
# Tesseract OCR Configuration  (Optional)
# ==============================================================================
# Path to Tesseract OCR executable (if not in system PATH)
# PYTESSERACT_PATH=/usr/bin/tesseract

# ==============================================================================
# Anonymized Telemetry
# ==============================================================================
# Set to false to disable ChromaDB telemetry
ANONYMIZED_TELEMETRY=false

# ==============================================================================
# Requirement extraction / diagrams (defaults)
# ==============================================================================
FLOWMIND_IMAGE_REQ_VLM_PASS=1
FLOWMIND_SKIP_SEMANTIC_LARGE_TEXT=0
FLOWMIND_USE_LLM_FINALIZE=1
FLOWMIND_VLM_MAX_WORKERS=3
# 1 = reject structured lines that lack shall/must/will/should (stricter SRS-style phrasing)
FLOWMIND_SRS_STRICT_VALIDATION=0
